{
  "manifest_version": 3,
  "name": "BOSS直聘助手",
  "version": "1.0.0",
  "description": "辅助沟通、消息分类与求职追踪 — 模板填充、快捷回复、数据统计",
  "default_locale": "zh_CN",
  "permissions": [
    "storage",
    "sidePanel",
    "alarms"
  ],
  "optional_permissions": [
    "notifications"
  ],
  "host_permissions": [
    "https://*.boss.cn/*",
    "https://*.zhipin.com/*",
    "https://api.deepseek.com/*",
    "https://api.xiaomimimo.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.boss.cn/*",
        "https://*.zhipin.com/*"
      ],
      "js": [
        "src/content/main.js"
      ],
      "css": [
        "styles/content.css",
        "src/content/ui/floating-badge.css"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_title": "BOSS直聘助手",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/panel.html"
  },
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/**/*.js",
        "src/**/*.css",
        "lib/**"
      ],
      "matches": [
        "https://*.boss.cn/*",
        "https://*.zhipin.com/*"
      ]
    }
  ]
}
